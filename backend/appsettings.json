{
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } }
  },
  "Jwt": {
    "Secret":        "${JWT_SECRET}",
    "Issuer":        "qablny-api",
    "Audience":      "qablny-app",
    "ExpiryMinutes": "60"
  },
  "LiveKit": {
    "ApiKey":     "${LIVEKIT_API_KEY}",
    "ApiSecret":  "${LIVEKIT_API_SECRET}",
    "ServerUrl":  "http://livekit:7880",
    "PublicUrl":  "ws://localhost:7880"
  },
  "MinIO": {
    "Endpoint":   "minio:9000",
    "AccessKey":  "${MINIO_ACCESS_KEY}",
    "SecretKey":  "${MINIO_SECRET_KEY}",
    "PublicUrl":  "http://localhost:9000"
  },
  "LibreTranslate": {
    "BaseUrl": "http://libretranslate:5000"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=qablny;Username=postgres;Password=${POSTGRES_PASSWORD}",
    "Redis": "redis:6379"
  },
  "AllowedHosts": "*"
}
