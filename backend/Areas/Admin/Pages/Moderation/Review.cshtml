@page
@model Qablny.Areas.Admin.Pages.Moderation.ReviewModel
@{
    ViewData["Title"] = "مراجعة المحتوى";
}

<div class="bx--row">
    <div class="bx--col-lg-12">
        <h1 class="bx--type-productive-heading-05" style="margin-bottom: 2rem;">مراجعة الصور والمحتوى</h1>
        <p class="bx--type-body-short-01" style="margin-bottom: 2rem;">مراجعة الصور الرمزية (Profile Pictures) للمستخدمين الجدد للموافقة عليها أو رفضها.</p>
    </div>
</div>

<div class="bx--row">
    @if(!Model.PendingUsers.Any()) {
        <div class="bx--col-lg-12">
            <p style="color: #525252; text-align: center; padding: 2rem;">لا توجد صور بانتظار المراجعة.</p>
        </div>
    }
    @foreach(var user in Model.PendingUsers)
    {
        <div class="bx--col-md-3" style="margin-bottom: 1rem;">
            <div class="bx--tile" style="text-align: center;">
                <img src="@user.ProfileImageUrl" alt="Avatar" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%; margin-bottom: 1rem;" />
                <h4 class="bx--type-productive-heading-02" style="margin-bottom: 0.5rem;">@user.Name</h4>
                <p style="font-size: 0.8rem; color: #525252; margin-bottom: 1rem;">@user.Id.ToString()[..8]</p>
                <div style="display: flex; gap: 0.5rem; justify-content: center;">
                    <button class="bx--btn bx--btn--sm bx--btn--primary">قبول</button>
                    <button class="bx--btn bx--btn--sm bx--btn--danger">رفض وحذف</button>
                </div>
            </div>
        </div>
    }
</div>
